{
	"permissions": {
		"allow": [
			"Bash(bun:*)",
			"Bash(bunx:*)",
			"Bash(git:*)",
			"Bash(gh:*)",
			"Bash(npx:playwright*)",
			"Bash(docker:*)",
			"Read",
			"Write",
			"Edit",
			"Glob",
			"Grep"
		],
		"deny": ["Bash(rm -rf /)", "Bash(curl:*)", "Bash(wget:*)"]
	},
	"env": {
		"PUBLIC_API_URL": "http://localhost:8000"
	}
}
